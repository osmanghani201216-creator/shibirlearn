rules_version = '2';
service cloud_firestore {
  match /databases/{database}/documents {

    // 1. Global safety net (Default deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Entity Validations
    function isValidReflection(data) {
      return data.keys().hasAll(['id', 'date', 'timestamp', 'text', 'category', 'userId'])
         && data.keys().size() == 6
         && data.id is string && data.id.size() <= 128
         && data.date is string && data.date.size() == 10
         && data.timestamp is int
         && data.text is string && data.text.size() <= 250
         && (data.category == 'deed' || data.category == 'gratitude')
         && data.userId == request.auth.uid;
    }

    function isValidPrayerLog(data) {
      return data.keys().hasAll(['date', 'timestamp', 'userId', 'fajr', 'dhuhr', 'asr', 'maghrib', 'isha'])
         && data.keys().size() <= 11
         && data.date is string && data.date.size() == 10
         && data.timestamp is int
         && data.userId == request.auth.uid
         && (data.fajr == 'pending' || data.fajr == 'alone' || data.fajr == 'jamat' || data.fajr == 'excused' || data.fajr == 'missed')
         && (data.dhuhr == 'pending' || data.dhuhr == 'alone' || data.dhuhr == 'jamat' || data.dhuhr == 'excused' || data.dhuhr == 'missed')
         && (data.asr == 'pending' || data.asr == 'alone' || data.asr == 'jamat' || data.asr == 'excused' || data.asr == 'missed')
         && (data.maghrib == 'pending' || data.maghrib == 'alone' || data.maghrib == 'jamat' || data.maghrib == 'excused' || data.maghrib == 'missed')
         && (data.isha == 'pending' || data.isha == 'alone' || data.isha == 'jamat' || data.isha == 'excused' || data.isha == 'missed')
         && (!data.keys().hasAny(['tahajjud']) || data.tahajjud == 'pending' || data.tahajjud == 'alone' || data.tahajjud == 'jamat' || data.tahajjud == 'excused' || data.tahajjud == 'missed')
         && (!data.keys().hasAny(['witr']) || data.witr == 'pending' || data.witr == 'alone' || data.witr == 'jamat' || data.witr == 'excused' || data.witr == 'missed')
         && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 500));
    }

    function isValidPublicProfile(data) {
      return data.keys().hasAll(['displayName'])
         && data.keys().size() <= 2
         && data.displayName is string && data.displayName.size() <= 100
         && (!data.keys().hasAny(['districtId']) || (data.districtId is string && data.districtId.size() <= 50));
    }

    function isValidPrivatePII(data) {
      return data.keys().hasAll(['email'])
         && data.keys().size() == 1
         && data.email is string && data.email.size() <= 100;
    }

    // 3. Document match definitions
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Daily reflections subcollection
      match /reflections/{reflectionId} {
        allow read: if isOwner(userId);
        allow create: if isVerifiedUser() && isOwner(userId) && isValidId(reflectionId) && isValidReflection(incoming());
        allow update: if isVerifiedUser() && isOwner(userId) && isValidId(reflectionId) && isValidReflection(incoming()) && incoming().userId == existing().userId && incoming().id == existing().id;
        allow delete: if isOwner(userId);
      }

      // Prayer logs subcollection
      match /prayer_logs/{date} {
        allow read: if isOwner(userId);
        allow create: if isVerifiedUser() && isOwner(userId) && isValidId(date) && isValidPrayerLog(incoming());
        allow update: if isVerifiedUser() && isOwner(userId) && isValidId(date) && isValidPrayerLog(incoming()) && incoming().userId == existing().userId && incoming().date == existing().date;
        allow delete: if isOwner(userId);
      }

      // Public profile
      match /public/profile {
        allow read: if isOwner(userId);
        allow create: if isVerifiedUser() && isOwner(userId) && isValidPublicProfile(incoming());
        allow update: if isVerifiedUser() && isOwner(userId) && isValidPublicProfile(incoming());
        allow delete: if isOwner(userId);
      }

      // Private PII
      match /private/info {
        allow read: if isOwner(userId);
        allow create: if isVerifiedUser() && isOwner(userId) && isValidPrivatePII(incoming());
        allow update: if isVerifiedUser() && isOwner(userId) && isValidPrivatePII(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
